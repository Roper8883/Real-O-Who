{
  "name": "@homeowner/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsup src/server.ts --format esm --out-dir dist --clean",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/swagger": "^9.5.2",
    "@fastify/swagger-ui": "^5.2.3",
    "@homeowner/auth": "workspace:*",
    "@homeowner/config": "workspace:*",
    "@homeowner/domain": "workspace:*",
    "@homeowner/notifications": "workspace:*",
    "@homeowner/search": "workspace:*",
    "@homeowner/types": "workspace:*",
    "fastify": "^5.6.1",
    "nanoid": "^5.1.6",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/node": "^20.19.17",
    "eslint": "^9.38.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
